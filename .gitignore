
# MRP_LOCAL - Git ignore

# Local tools / machine-specific
.codex/
.vscode/settings.json
.idea/

# Secrets / environment
.env
.env.*
!.env.example
*.key
*.pem
*.pfx
*.crt
*.cer
secrets.*
credentials.*
token.*
auth.json

# Python
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Node / frontend
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.next/
.nuxt/
.cache/
.parcel-cache/
.vite/
dist/
build/

# Runtime / database / generated data
logs/
runtime/
cache/
temp/
tmp/
*.log
*.pid
*.tmp
*.temp
*.db
*.sqlite
*.sqlite3
*.dump
*.bak
*.backup
pgdata/
postgres_data/
database/data/
database/backups/

# System files
.DS_Store
Thumbs.db
desktop.ini

# Office temp
~$*.doc*
~$*.xls*
~$*.ppt*

# Local backups and generated packages
backup/
backups/
_bkp/
*.old
*.orig
*.7z
*.rar
*.zip

# Allow intentional release marker docs, but not binary packages by default.
!03-vs/releases/.gitkeep
!03-vs/pacotes/.gitkeep
