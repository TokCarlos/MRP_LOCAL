# =========================================================
# MRP_LOCAL - Git ignore
# =========================================================

# Codex local
.codex/
.codex/**

# Secrets / ambiente
.env
.env.*
!.env.example
*.key
*.pem
*.pfx
*.crt
*.cer
secrets.*
credentials.*
token.*
auth.json

# Python
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Node / frontend
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.next/
.nuxt/
.cache/
.parcel-cache/
.vite/
dist/
build/

# Banco local / runtime
*.db
*.sqlite
*.sqlite3
*.dump
*.bak
*.backup

# PostgreSQL local / dados reais
pgdata/
postgres_data/
database/data/
database/backups/

# Logs / runtime / temporarios
logs/
runtime/
cache/
temp/
tmp/
*.log
*.tmp
*.temp
01-mrp/logs/**/*.log
*.pid

# Arquivos de sistema
.DS_Store
Thumbs.db
desktop.ini

# Office temporarios
~$*.doc*
~$*.xls*
~$*.ppt*
*.tmp

# Backups locais
backup/
backups/
_bkp/
*.old
*.orig

# IDE
.vscode/settings.json
.vscode/.ropeproject/
.idea/

# Arquivos compactados pesados gerados
*.7z
*.rar

# Pacotes compactados gerados localmente
*.zip
!03-vs/pacotes/.gitkeep
!03-vs/releases/.gitkeep
# MRP_LOCAL runtime 01-mrp - manter estrutura, ignorar conteudo real
01-mrp/logs/**
!01-mrp/logs/
!01-mrp/logs/.gitkeep
!01-mrp/logs/**/
!01-mrp/logs/**/.gitkeep
01-mrp/tmp/**
!01-mrp/tmp/
!01-mrp/tmp/.gitkeep
01-mrp/backups/**
!01-mrp/backups/
!01-mrp/backups/.gitkeep
01-mrp/db/**
!01-mrp/db/
!01-mrp/db/.gitkeep
!01-mrp/db/README.md
01-mrp/runtime/**
!01-mrp/runtime/
!01-mrp/runtime/.gitkeep
!01-mrp/runtime/README.md
01-mrp/cache/**
01-mrp/**/Thumbs.db
01-mrp/**/*.pyc
01-mrp/**/__pycache__/
