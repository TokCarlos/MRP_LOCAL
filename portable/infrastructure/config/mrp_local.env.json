{
    "schema": "mrp_local.env.v1",
    "status": "PORTABLE_FUNCIONAL_LOCAL",
    "observacao": "Pacote portable funcional para teste em outra maquina, sem dependencia de arvore DEV.",
    "project_root_mode": "auto_from_script",
    "frontend": {
        "relative_dir": "app/frontend",
        "index_file": "index.html",
        "port": 8765,
        "bind": "0.0.0.0",
        "health_path": "/index.html",
        "startup_wait_seconds": 8
    },
    "logs": {
        "relative_dir": "logs",
        "encoding": "utf-8-no-bom"
    },
    "windows_task": {
        "name": "MRP_LOCAL_FRONTEND",
        "default_schedule": "ONLOGON",
        "runner": "powershell.exe",
        "execution_policy": "Bypass"
    },
    "watchdog": {
        "interval_seconds": 15,
        "max_restarts_per_hour": 20,
        "restart_cooldown_seconds": 60
    },
    "python": {
        "preferred_relative_exe": "runtime/python/python.exe",
        "allow_py_launcher": true,
        "allow_python_path": true
    },
    "future_installer_hook": {
        "target": "MRP_LOCAL deve virar programa instalavel/empacotado.",
        "clean_machine_rule": "Uma maquina limpa deve receber precheck, runtime, arquivos, config, firewall, tarefa, watchdog e healthcheck.",
        "business_rule": "Instalador prepara ambiente; motor de regra de negocio continua desacoplado do ambiente fisico."
    }
}
